# ═══════════════════════════════════════════════════
# Hammam Nour — Environment Variables
# Copy this to .env.local and fill in the values
# ═══════════════════════════════════════════════════

# ── Resend (Email) ──────────────────────────────────
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# From address (use "onboarding@resend.dev" for testing,
# or verify your own domain at resend.com/domains)
RESEND_FROM_EMAIL="Hammam Nour <onboarding@resend.dev>"

# Spa email to receive booking notifications
BOOKING_NOTIFICATION_EMAIL=spa@hammamnour.com

# ── Google Sheets (Calendar/Availability) ───────────
# 1. Go to https://console.cloud.google.com
# 2. Create project > Enable "Google Sheets API"
# 3. Create Service Account > Download JSON key
# 4. Create a Google Sheet with header row:
#    ID | Treatment | Date | Time | Duration | Name | Email | Phone | Requests | Price | Created
# 5. Share the sheet with the service account email (Editor)
# 6. Copy the spreadsheet ID from the URL:
#    https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit

GOOGLE_SERVICE_ACCOUNT_EMAIL=hammam@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_spreadsheet_id_here
